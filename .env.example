# =============================================================
# clipfarmer environment variables
# Copy this to .env and fill in real values. Never commit .env.
# =============================================================

# --- Whop -----------------------------------------------------
WHOP_EMAIL=
WHOP_PASSWORD=
# Comma-separated list of Whop community slugs to scan (whop.com/joined/<slug>/)
WHOP_COMMUNITIES=clip-farm-official,whop-creators-ugc

# --- Anthropic (Claude) ---------------------------------------
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-20250514 per project spec
# (Sonnet 4.6 = claude-sonnet-4-6 is newer — consider upgrading)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Whisper (local transcription) ----------------------------
# tiny | base | small | medium | large
WHISPER_MODEL=base
# cpu | cuda
WHISPER_DEVICE=cpu

# --- Metricool (single publisher for all 3 platforms) ---------
# Get from https://app.metricool.com → Profile → Personal Access Token
METRICOOL_API_TOKEN=
# Brand / blog id (numeric). Visible in app URL when a brand is selected
METRICOOL_BRAND_ID=
# Optional: required by some Metricool endpoints
METRICOOL_USER_ID=
# Connected social-account ids inside Metricool for this brand.
# These come back from Metricool's /v2/accounts endpoint.
METRICOOL_TIKTOK_ACCOUNT_ID=
METRICOOL_YOUTUBE_ACCOUNT_ID=
METRICOOL_INSTAGRAM_ACCOUNT_ID=

# --- Telegram (approval + notifications) ----------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# When true, every post and every Whop submission waits for your /approve
REQUIRE_TELEGRAM_APPROVAL=true

# --- Scheduling -----------------------------------------------
SCAN_INTERVAL_MINUTES=60
POST_INTERVAL_MINUTES=90
SCREENSHOT_AFTER_HOURS=48

# --- Clip engine ----------------------------------------------
CLIP_MIN_SECONDS=30
CLIP_MAX_SECONDS=60
CLIPS_PER_SOURCE=3

# --- Campaign viability filter --------------------------------
# Only clip campaigns with at least this % of budget remaining
MIN_BUDGET_REMAINING_PCT=60

# --- FFmpeg ---------------------------------------------------
# Leave as "ffmpeg" if it's on PATH, otherwise full path
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Skip TikTok publisher (set to true while you're locked out / not logged in)
SKIP_TIKTOK=false
